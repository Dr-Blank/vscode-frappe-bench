{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "watch",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "problemMatcher": "$tsc-watch"
        },
        {
            "label": "Assets: SVG to PNG",
            "type": "shell",
            "command": "npx --yes sharp-cli -i assets/logo.svg -o assets/logo.png resize 128 128",
            "group": "none",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Release: Bump Version",
            "type": "shell",
            "command": "npm version ${input:bumpType} --message 'chore(release): bump v%s' && git push --follow-tags",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated"
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "bumpType",
            "type": "pickString",
            "description": "Version bump type",
            "options": ["patch", "minor", "major"],
            "default": "patch"
        }
    ]
}
