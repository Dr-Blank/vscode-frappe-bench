{
    "version": "2.0.0",
    "tasks": [
        {
            "type": "npm",
            "script": "watch",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "isBackground": true,
            "problemMatcher": "$tsc-watch"
        },
        {
            "label": "Assets: SVG to PNG",
            "type": "shell",
            "command": "npx --yes sharp-cli -i assets/logo.svg -o assets/logo.png resize 128 128",
            "group": "none",
            "presentation": {
                "reveal": "silent",
                "panel": "shared"
            },
            "problemMatcher": []
        },
        {
            "label": "Release: Bump Version",
            "type": "shell",
            "command": "node scripts/bump.mjs --type=${input:releaseType} --bump=${input:bumpType}",
            "group": "none",
            "presentation": {
                "reveal": "always",
                "panel": "dedicated",
                "focus": true
            },
            "problemMatcher": []
        }
    ],
    "inputs": [
        {
            "id": "bumpType",
            "type": "pickString",
            "description": "Version bump type",
            "options": ["patch", "minor", "major"],
            "default": "patch"
        },
        {
            "id": "releaseType",
            "type": "pickString",
            "description": "Release type (pre-release = odd minor, release = even minor)",
            "options": ["pre-release", "release"],
            "default": "pre-release"
        }
    ]
}
